# ── AuraSphere frontend environment ───────────────────────────────────────────
# Only VITE_* vars are exposed to the browser. These are PUBLIC — no secrets.
# Copy to `.env` (dev) and/or `.env.production` (build).

# Base URL of the backend API
VITE_API_URL=http://localhost:8080

# Socket.IO URL (usually same as the API)
VITE_SOCKET_URL=http://localhost:8080

# Google OAuth client ID (public value from Google Cloud console)
VITE_GOOGLE_CLIENT_ID=
