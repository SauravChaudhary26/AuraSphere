# ── AuraSphere backend environment ────────────────────────────────────────────
# Copy to `.env` and fill in. NEVER commit the real .env.

# Core (required)
NODE_ENV=development
PORT=8080
MONGO_CONN=mongodb://localhost:27017/aurasphere
# Generate a strong secret:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# IANA timezone that defines the "day" for streaks (optional, default Asia/Kolkata)
# DAY_TIMEZONE=Asia/Kolkata
JWT_EXPIRES_IN=7d

# URLs
# CLIENT_URL is the frontend origin (also the CORS allow-list; comma-separate several).
CLIENT_URL=http://localhost:3000
# APP_URL is THIS backend's public URL (used to build OAuth redirect URIs).
APP_URL=http://localhost:8080

# Cron (protects POST /cron/* ; required to trigger the leaderboard rebuild externally)
CRON_SECRET=replace-with-a-random-string

# ── Optional integrations (features degrade gracefully if unset) ──────────────

# Email (password reset + deadline reminders) — https://resend.com
RESEND_API_KEY=
EMAIL_FROM=AuraSphere <onboarding@resend.dev>

# Google login — https://console.cloud.google.com  (OAuth 2.0 client)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=postmessage

# GitHub login — https://github.com/settings/developers
# Authorization callback URL: {APP_URL}/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Facebook login — https://developers.facebook.com/apps
# Valid OAuth redirect URI: {APP_URL}/auth/facebook/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
